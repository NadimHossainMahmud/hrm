// HRForge Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenancy & Auth
model Tenant {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  logoUrl         String?
  industry        String?
  companySize     String?
  timezone        String    @default("UTC")
  dateFormat      String    @default("YYYY-MM-DD")
  fiscalYearStart Int       @default(1)
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users              User[]
  roles              Role[]
  departments        Department[]
  locations          Location[]
  employees          Employee[]
  subscriptions      Subscription[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  workflowTemplates  WorkflowTemplate[]
  workflowInstances  WorkflowInstance[]
  jobPostings        JobPosting[]
  hiringPipelines    HiringPipeline[]
  documentTemplates  DocumentTemplate[]
  applicants         Applicant[]
  interviewScorecards InterviewScorecard[]
  offerLetters       OfferLetter[]
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  isActive         Boolean   @default(true)
  
  // MFA fields
  mfaSecret        String?   // Encrypted TOTP secret
  mfaEnabled       Boolean   @default(false)
  mfaBackupCodes   String[]  // Hashed backup codes
  
  // Email verification
  emailVerified    Boolean   @default(false)
  emailVerifyToken String?
  
  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  userRoles            UserRole[]
  refreshTokens        RefreshToken[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference[]
  initiatedWorkflows   WorkflowInstance[]
  workflowApprovals    WorkflowApproval[]
}

model Role {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  
  users       User[]
  userRoles   UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String     @id @default(uuid())
  key         String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Core HR
model Department {
  id          String     @id @default(uuid())
  name        String
  description String?
  parentId    String?
  parent      Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenantId    String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  employees     Employee[]
  jobPostings   JobPosting[]
}

model Location {
  id          String   @id @default(uuid())
  name        String
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?
  timezone    String   @default("UTC")
  isHeadquarters Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employees   Employee[]
  jobPostings JobPosting[]
}

model Employee {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?
  startDate     DateTime
  endDate       DateTime?
  employmentType String
  jobTitle      String
  salary        Float?
  currency      String?  @default("USD")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  locationId    String?
  location      Location?   @relation(fields: [locationId], references: [id])
  managerId     String?
  manager            Employee?   @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports      Employee[]  @relation("EmployeeManager")
  jobPostingsManaged JobPosting[] @relation("HiringManager")
  referredApplicants Applicant[]  @relation("Referral")
  scorecards         InterviewScorecard[]
}

// Subscription & Billing
model Plan {
  id                String   @id @default(uuid())
  name              String   @unique
  slug              String   @unique
  description       String?
  price             Float
  interval          String   @default("month")
  stripePriceId     String?  // Stripe Price ID
  maxEmployees      Int?
  maxJobs           Int?
  maxCourses        Int?
  features          Json
  isActive          Boolean  @default(true)
  isPopular         Boolean  @default(false)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  planFeatures      PlanFeature[]
  subscriptions     Subscription[]
}

model PlanFeature {
  id          String   @id @default(uuid())
  featureKey  String
  name        String
  description String?
  limit       Int?     // null = unlimited
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())

  planId      String
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
}

model Subscription {
  id                   String   @id @default(uuid())
  status               String   @default("trialing") // trialing, active, past_due, canceled, incomplete
  stripeSubscriptionId String?  @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  canceledAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  planId               String
  plan                 Plan     @relation(fields: [planId], references: [id])
}

// Notifications (Phase 4)
model Notification {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String    // e.g. 'time_off_approved', 'review_assigned', 'workflow_approval'
  title        String?
  message      String?
  resourceType String?
  resourceId   String?
  isRead       Boolean   @default(false)
  readAt       DateTime?
  channel      String    @default("in_app") // in_app, email, both
  createdAt    DateTime  @default(now())

  @@index([tenantId, userId])
  @@index([userId, isRead])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  tenantId  String   // for tenant-scoped queries
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String   // e.g. 'time_off_approved', 'workflow_approval'
  inApp     Boolean  @default(true)
  email     Boolean  @default(true)

  @@unique([userId, eventType])
  @@index([tenantId])
  @@index([userId])
}

// Workflows (Phase 4)
model WorkflowTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  triggerType String   // time_off, expense, promotion, termination, custom
  description String?
  isActive    Boolean  @default(true)
  steps       Json     // [{ order, approverType, approverId, condition, autoApproveDays }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instances   WorkflowInstance[]
}

model WorkflowInstance {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId   String?
  template     WorkflowTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  resourceType String    // time_off_request, compensation_change, etc.
  resourceId   String?
  initiatedBy  String
  user         User      @relation(fields: [initiatedBy], references: [id], onDelete: Cascade)
  status       String    @default("pending") // pending, in_progress, approved, rejected, canceled
  currentStep  Int       @default(0)
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  approvals    WorkflowApproval[]
}

model WorkflowApproval {
  id         String   @id @default(uuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  tenantId   String   // denormalized for RLS/query
  stepOrder  Int
  approverId String
  user       User     @relation(fields: [approverId], references: [id], onDelete: Cascade)
  status     String   @default("pending") // pending, approved, rejected, skipped
  decisionAt DateTime?
  comments   String?

  @@index([instanceId])
  @@index([approverId, status])
}

// Document templates (offer letters, etc.) — Phase 5
model DocumentTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      String   // offer_letter, policy, etc.
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerLetters OfferLetter[]
}

// Hiring & ATS — Phase 5
model JobPosting {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  locationId       String?
  location         Location?   @relation(fields: [locationId], references: [id])
  hiringManagerId  String?
  hiringManager    Employee?   @relation("HiringManager", fields: [hiringManagerId], references: [id])
  description      String?    @db.Text
  requirements     String?    @db.Text
  employmentType   String?
  salaryMin        Decimal?   @db.Decimal(12, 2)
  salaryMax        Decimal?   @db.Decimal(12, 2)
  salaryCurrency   String?    @default("USD")
  showSalary       Boolean    @default(false)
  status           String     @default("draft") // draft, open, paused, closed, filled
  publishedAt      DateTime?
  closesAt        DateTime?
  remotePolicy     String?    // onsite, hybrid, remote
  pipelineId       String?
  pipeline         HiringPipeline? @relation(fields: [pipelineId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  applicants Applicant[]
}

model HiringPipeline {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages    PipelineStage[]
  jobPostings JobPosting[]
}

model PipelineStage {
  id             String   @id @default(uuid())
  pipelineId     String
  pipeline       HiringPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name           String
  stageOrder     Int
  stageType      String?  // application, assessment, interview, offer, hired
  autoRejectDays Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applicants Applicant[]
  scorecards  InterviewScorecard[]
}

model Applicant {
  id                   String    @id @default(uuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobPostingId         String
  jobPosting           JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  firstName            String
  lastName             String
  email                String
  phone                String?
  resumeUrl            String?
  coverLetter          String?   @db.Text
  linkedinUrl          String?
  source               String?   // careers_page, linkedin, referral, indeed
  referralEmployeeId   String?
  referralEmployee     Employee?  @relation("Referral", fields: [referralEmployeeId], references: [id])
  currentStageId       String?
  currentStage         PipelineStage? @relation(fields: [currentStageId], references: [id])
  status               String    @default("active") // active, withdrawn, rejected, hired
  rating               Int?
  rejectionReason      String?
  hiredDate            DateTime?
  appliedAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  scorecards   InterviewScorecard[]
  offerLetters OfferLetter[]
}

model InterviewScorecard {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicantId    String
  applicant      Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  interviewerId  String
  interviewer    Employee  @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  stageId        String?
  stage          PipelineStage? @relation(fields: [stageId], references: [id])
  overallRating  Int?
  recommendation String?  // strong_yes, yes, no, strong_no
  notes          String?  @db.Text
  scores         Json?
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([applicantId])
}

model OfferLetter {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  templateId   String?
  template     DocumentTemplate? @relation(fields: [templateId], references: [id])
  content      String?   @db.Text
  salary       Decimal?  @db.Decimal(12, 2)
  startDate    DateTime? @db.Date
  status       String    @default("draft") // draft, sent, viewed, accepted, declined, expired
  sentAt       DateTime?
  expiresAt    DateTime?
  respondedAt  DateTime?
  signatureUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([applicantId])
}

// Audit Log
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}
